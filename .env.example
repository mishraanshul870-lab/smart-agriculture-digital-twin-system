# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI API calls when AI_PROVIDER is set to openai.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# AI_PROVIDER: The active AI model provider to use ('openai' | 'gemini' | 'mock').
# If the required API key for the chosen provider is missing, the system will fall back to mock.
AI_PROVIDER="mock"

# MONGODB_URI: Required for database persistence.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/agri-twin"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
